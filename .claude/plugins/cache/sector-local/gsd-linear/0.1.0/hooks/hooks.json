{
  "description": "Detects GSD phase lifecycle bash calls and triggers Linear sync",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/detect-gsd-phase.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
